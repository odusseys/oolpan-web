PORT=4000
CLIENT_ORIGIN=http://localhost:5173
OOLPAN_STORAGE_DATABASE_URL=
OOLPAN_STORAGE_DATABASE_URL_UNPOOLED=
GOOGLE_CLIENT_ID=

# Leave the keys blank to run in mock mode.
# Translation uses OpenAI by default.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-5.4-mini
OPENAI_AUDIO_MODEL=gpt-4o-mini-tts
OPENAI_AUDIO_VOICE=cedar

# Image generation uses FAL Flux Schnell by default.
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# Optional provider-specific overrides if you want a different OpenAI-compatible service.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=
IMAGE_SIZE=1024x1024
